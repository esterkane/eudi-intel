# Copy to .env and adjust. .env is gitignored.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=eudi
POSTGRES_PASSWORD=eudi
POSTGRES_DB=eudi
DATABASE_URL=postgresql+asyncpg://eudi:eudi@postgres:5432/eudi

# ── Qdrant / Redis ──────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
QDRANT_LATEST_COLLECTION=eudi_latest
QDRANT_HISTORY_COLLECTION=eudi_history

# ── Ollama (runs on the HOST for GPU; containers reach it via host.docker.internal) ──
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Models (do not exceed the sizes in CLAUDE.md) ───────────────────────────
GEN_MODEL=qwen3:8b               # Ollama tag; Q4_K_M. Multilingual. ~5-6GB VRAM @ 8K ctx.
GEN_CONTEXT_TOKENS=8192          # HARD CAP for 8GB VRAM. Do not raise on this card.
EMBEDDING_MODEL=BAAI/bge-m3      # CPU via FastEmbed/ONNX. dense + sparse.
RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # CPU. rerank top ~30 only.
RERANK_ENABLED=true
RERANK_CANDIDATES=30

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── MCP (read-only agent tools; see docs/mcp.md) ────────────────────────────
MCP_TRANSPORT=stdio               # stdio (Claude Code / local) | http
MCP_HTTP_HOST=127.0.0.1           # bind host for http transport
MCP_HTTP_PORT=8800                # bind port for http transport
MCP_ALLOW_MUTATIONS=false         # hard read-only guard; no mutating tool exists

# ── GitHub access ───────────────────────────────────────────────────────────
# Leave EMPTY for token-free mode (git clone + atom feeds + HTML scrape).
# If you ever add a Personal Access Token, collectors switch to authenticated
# REST (5000 req/hr) automatically. No other change needed.
GITHUB_TOKEN=

# ── Ingestion ───────────────────────────────────────────────────────────────
REPOS_DIR=/data/repos             # git mirror directory inside containers (compose volume)

# ── Ingestion cadence (Celery Beat; seconds) ────────────────────────────────
POLL_FEEDS_INTERVAL=10800         # release/tag/commit atom feeds: every 3h
SCRAPE_ISSUES_INTERVAL=21600      # issue/PR/discussion HTML: every 6h
CRAWL_DOCS_INTERVAL=86400         # eudi.dev / docs / conformance / EC crawl: daily
GIT_PULL_INTERVAL=43200           # repo clone/pull refresh: every 12h
